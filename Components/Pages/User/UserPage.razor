@page "/user"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using DnDNoteKeeper.Data
@using DnDNoteKeeper.Models
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@attribute [Authorize]
@inject DnDDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard - DnD Note Keeper</PageTitle>

<!-- Welcome Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <AuthorizeView>
            <h1 class="h3 mb-1">Welcome back @(context.User.Identity?.Name ?? "Unknown User")!</h1>
            <p class="text-muted mb-0">Ready to continue your epic journey?</p>
        </AuthorizeView>
    </div>
    <div class="d-none d-md-block">
        <a href="/campaigns/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>New Campaign
        </a>
    </div>
</div>

<!-- Mobile Quick Create -->
<div class="d-block d-md-none mb-4">
    <a href="/campaigns/create" class="btn btn-primary w-100">
        <i class="bi bi-plus-circle me-2"></i>Create New Campaign
    </a>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-primary mb-2">
                    <i class="bi bi-journal-bookmark fs-2"></i>
                </div>
                <h4 class="mb-1">@campaigns.Count</h4>
                <small class="text-muted">Campaigns</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-success mb-2">
                    <i class="bi bi-people fs-2"></i>
                </div>
                <h4 class="mb-1">@characters.Count</h4>
                <small class="text-muted">Characters</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-warning mb-2">
                    <i class="bi bi-dice-6 fs-2"></i>
                </div>
                <a href="/dice-roller" class="stretched-link text-decoration-none">
                    <small class="text-muted">Dice Roller</small>
                </a>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-info mb-2">
                    <i class="bi bi-plus-circle fs-2"></i>
                </div>
                <a href="/characters/create" class="stretched-link text-decoration-none">
                    <small class="text-muted">New Character</small>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-md-12">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-lightning-charge me-2 text-primary"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6 col-lg-3">
                        <a href="/campaigns/create" class="btn btn-outline-primary w-100 text-center">
                            <i class="bi bi-journal-plus d-block fs-4 mb-1"></i>
                            <small>New Campaign</small>
                        </a>
                    </div>
                    <div class="col-6 col-lg-3">
                        <a href="/characters/create" class="btn btn-outline-success w-100 text-center">
                            <i class="bi bi-person-plus d-block fs-4 mb-1"></i>
                            <small>Create Character</small>
                        </a>
                    </div>
                    <div class="col-6 col-lg-3">
                        <a href="/world-maps" class="btn btn-outline-secondary w-100 text-center">
                            <i class="bi bi-map d-block fs-4 mb-1"></i>
                            <small>World Maps</small>
                        </a>
                    </div>
                    <div class="col-6 col-lg-3">
                        <a href="/notes" class="btn btn-outline-danger w-100 text-center">
                            <i class="bi bi-pencil-square d-block fs-4 mb-1"></i>
                            <small>Quick Note</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Campaigns & Characters -->
<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-journal-bookmark me-2 text-primary"></i>Recent Campaigns
                </h5>
                <a href="/campaigns" class="btn btn-sm btn-outline-primary">All Campaigns</a>
            </div>
            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading...
                    </div>
                }
                else if (recentCampaigns.Count == 0)
                {
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-journal-x fs-3 d-block mb-2"></i>
                        No campaigns yet.
                        <a href="/campaigns/create" class="d-block mt-2">Create your first campaign</a>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var campaign in recentCampaigns)
                        {
                            <a href="/campaigns" class="list-group-item list-group-item-action">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">@campaign.CampaignName</h6>
                                        @if (!string.IsNullOrEmpty(campaign.Location))
                                        {
                                            <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@campaign.Location</small>
                                        }
                                    </div>
                                    <i class="bi bi-chevron-right text-muted"></i>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2 text-success"></i>Your Characters
                </h5>
                <a href="/characters" class="btn btn-sm btn-outline-success">View All</a>
            </div>
            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading...
                    </div>
                }
                else if (characters.Count == 0)
                {
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-person-x fs-3 d-block mb-2"></i>
                        No characters yet.
                        <a href="/characters/create" class="d-block mt-2">Create your first character</a>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var character in characters)
                        {
                            <a href="/characters" class="list-group-item list-group-item-action">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">@character.Name</h6>
                                        <small class="text-muted">Level @character.Level @character.Race @character.Class</small>
                                    </div>
                                    <span class="badge bg-secondary">Lvl @character.Level</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .list-group-item-action:hover {
        background-color: #f8f9fa;
    }
</style>

@code {
    private List<CampaignDetails> campaigns = [];
    private List<CampaignDetails> recentCampaigns = [];
    private List<Character> characters = [];
    private bool isLoading = true;
    private int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdClaim, out currentUserId))
        {
            campaigns = await DbContext.Campaigns
                .Where(c => c.UserId == currentUserId)
                .ToListAsync();

            recentCampaigns = campaigns
                .OrderByDescending(c => c.Id)
                .Take(5)
                .ToList();

            characters = await DbContext.Characters
                .Where(c => c.UserId == currentUserId)
                .OrderByDescending(c => c.CharacterId)
                .ToListAsync();
        }

        isLoading = false;
    }
}