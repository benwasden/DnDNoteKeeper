@page "/user"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Dashboard - DnD Note Keeper</PageTitle>

<!-- Welcome Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <AuthorizeView>
            <h1 class="h3 mb-1">Welcome back @(context.User.Identity?.Name ?? "Unknown User")!</h1>
            <p class="text-muted mb-0">Ready to continue your epic journey?</p>
        </AuthorizeView>
    </div>
    <div class="d-none d-md-block">
        <button class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>New Campaign
        </button>
    </div>
</div>

<!-- Mobile Quick Create -->
<div class="d-block d-md-none mb-4">
    <button class="btn btn-primary w-100">
        <i class="bi bi-plus-circle me-2"></i>Create New Campaign
    </button>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-primary mb-2">
                    <i class="bi bi-journal-bookmark fs-2"></i>
                </div>
                <h4 class="mb-1">3</h4>
                <small class="text-muted">Active Campaigns</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-success mb-2">
                    <i class="bi bi-people fs-2"></i>
                </div>
                <h4 class="mb-1">12</h4>
                <small class="text-muted">Characters</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-warning mb-2">
                    <i class="bi bi-clock-history fs-2"></i>
                </div>
                <h4 class="mb-1">47</h4>
                <small class="text-muted">Sessions Played</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center h-100">
            <div class="card-body p-3">
                <div class="text-info mb-2">
                    <i class="bi bi-file-text fs-2"></i>
                </div>
                <h4 class="mb-1">156</h4>
                <small class="text-muted">Total Notes</small>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-lightning-charge me-2 text-primary"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6 col-lg-3">
                        <button class="btn btn-outline-primary w-100 text-start">
                            <i class="bi bi-journal-plus d-block fs-4 mb-1"></i>
                            <small>New Campaign</small>
                        </button>
                    </div>
                    <div class="col-6 col-lg-3">
                        <button class="btn btn-outline-success w-100 text-start">
                            <i class="bi bi-person-plus d-block fs-4 mb-1"></i>
                            <small>Create Character</small>
                        </button>
                    </div>
                    <div class="col-6 col-lg-3">
                        <button class="btn btn-outline-info w-100 text-start">
                            <i class="bi bi-map d-block fs-4 mb-1"></i>
                            <small>New World Map</small>
                        </button>
                    </div>
                    <div class="col-6 col-lg-3">
                        <button class="btn btn-outline-warning w-100 text-start">
                            <i class="bi bi-pencil-square d-block fs-4 mb-1"></i>
                            <small>Quick Note</small>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="bi bi-calendar-event me-2 text-success"></i>Next Session
                </h6>
            </div>
            <div class="card-body text-center">
                <h4 class="text-primary">Tomorrow</h4>
                <p class="mb-2">The Lost Mines</p>
                <small class="text-muted d-block">7:00 PM - 10:00 PM</small>
                <button class="btn btn-sm btn-outline-primary mt-2">View Details</button>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity & Active Campaigns -->
<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-journal-bookmark me-2 text-primary"></i>Active Campaigns
                </h5>
                <a href="#" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">The Lost Mines of Phandelver</h6>
                                <p class="mb-1 small text-muted">Level 3 • Session 8</p>
                                <small class="text-success">
                                    <i class="bi bi-clock me-1"></i>Last played 2 days ago
                                </small>
                            </div>
                            <span class="badge bg-primary rounded-pill">DM</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">Curse of Strahd</h6>
                                <p class="mb-1 small text-muted">Level 6 • Session 15</p>
                                <small class="text-warning">
                                    <i class="bi bi-clock me-1"></i>Last played 1 week ago
                                </small>
                            </div>
                            <span class="badge bg-success rounded-pill">Player</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">Homebrew: The Shattered Realms</h6>
                                <p class="mb-1 small text-muted">Level 12 • Session 23</p>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>Last played 2 weeks ago
                                </small>
                            </div>
                            <span class="badge bg-primary rounded-pill">DM</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-activity me-2 text-success"></i>Recent Activity
                </h5>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker bg-primary"></div>
                        <div class="timeline-content">
                            <h6 class="mb-1 small">Updated Character Sheet</h6>
                            <p class="mb-1 small text-muted">Added new spell: Fireball to Wizard build</p>
                            <small class="text-muted">2 hours ago</small>
                        </div>
                    </div>
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker bg-success"></div>
                        <div class="timeline-content">
                            <h6 class="mb-1 small">Session Note Added</h6>
                            <p class="mb-1 small text-muted">Recorded encounter with the Green Dragon</p>
                            <small class="text-muted">Yesterday</small>
                        </div>
                    </div>
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker bg-warning"></div>
                        <div class="timeline-content">
                            <h6 class="mb-1 small">New Campaign Created</h6>
                            <p class="mb-1 small text-muted">Started "The Shattered Realms" campaign</p>
                            <small class="text-muted">3 days ago</small>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker bg-info"></div>
                        <div class="timeline-content">
                            <h6 class="mb-1 small">Character Level Up</h6>
                            <p class="mb-1 small text-muted">Theron reached level 6!</p>
                            <small class="text-muted">1 week ago</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 20px;
    }
    
    .timeline::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #dee2e6;
    }
    
    .timeline-item {
        position: relative;
    }
    
    .timeline-marker {
        position: absolute;
        left: -16px;
        top: 4px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid #fff;
        box-shadow: 0 0 0 2px #dee2e6;
    }
    
    .timeline-content {
        background: #f8f9fa;
        padding: 12px;
        border-radius: 8px;
        border-left: 3px solid #dee2e6;
    }
</style>