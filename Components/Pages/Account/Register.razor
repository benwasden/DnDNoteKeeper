@page "/register"
@using DnDNoteKeeper.Data
@using DnDNoteKeeper.Models
@using DnDNoteKeeper.Models.ViewModels
@using DnDNoteKeeper.Services
@inject DnDDbContext appDbContext
@inject NavigationManager navigationManager

<div class="mt-3">
    <h3>Welcome to DnD Note Taker!</h3>
    <span>Register an account here and proceed to login!</span>
</div>
<div class="row mt-3">
    <div class="border rounded p-3">
        <EditForm Model="@RegModel" OnValidSubmit="HandleRegistration" FormName="RegisterForm">
            <DataAnnotationsValidator />
            <h4>Create Account</h4>
            
            <div class="mb-3">
                <label>Username</label>
                <InputText @bind-Value="RegModel.UserName" class="form-control" />
                <ValidationMessage For="() => RegModel.UserName" />
            </div>
            <div class="mb-3">
                <label>Password</label>
                <InputText @bind-Value="RegModel.Password" type="password" class="form-control" />
                <ValidationMessage For="() => RegModel.Password" />
            </div>
            
            <div class="mb-2">
                <span class="text-danger">@errorMessage</span>
            </div>
            <div class="d-flex justify-content-center">
                <button type="submit" class="btn btn-success">Register</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    // Form validation
    [SupplyParameterFromForm]
    public required LoginViewModel RegModel { get; set; }

    protected override void OnInitialized()
    {
        RegModel ??= new();
    }

    private string? errorMessage;

    // Takes form info, compares against what's in db, registers user in db if all conditions are met
    private async Task HandleRegistration() {
        try {
            // Checks to see if username already exists in db
            var existing = appDbContext.UserAccounts.Any(x => x.UserName == RegModel.UserName);

            // Rejects if username exists
            if (existing) {
                errorMessage = "Username already taken.";
                return;
            }
            // Defining specified credentials against UserAccount model
            var newUser = new UserAccount {
                UserName = RegModel.UserName,
                // Uses the PasswordHasher service to hash password before sending to db
                Password = PasswordHasher.HashPassword(RegModel.Password ?? string.Empty) 
            };

            // Adds user to db (ID's generated and autoincrements, username and hashed pwd sent)
            appDbContext.UserAccounts.Add(newUser);
            await appDbContext.SaveChangesAsync();
            
            // Navigates to the home page
            navigationManager.NavigateTo("/login");
        } catch (Exception ex) {
            Console.WriteLine(ex);
            errorMessage = "A database error occured (likely timed out). Please try again in a few seceonds!";
        }
    }
}