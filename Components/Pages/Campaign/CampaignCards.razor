@page "/campaigns"
@using DnDNoteKeeper.Data
@using DnDNoteKeeper.Models
@using DnDNoteKeeper.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject DnDDbContext appDbContext
@attribute [Authorize]

<div class="container mt-4">
    <h2 class="text-white mb-4">Active Campaigns</h2>

    @if (campaignList == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @* Iterates through each entry in campaign table *@
            @foreach (var campaign in campaignList)
            {
                @* Resolved issues I had with clickable components *@
                <CampaignCard Campaign="campaign" @rendermode="InteractiveServer" />
            }
        </div>
    }
</div>

@code {
    private List<CampaignDetails>? campaignList;

    protected override async Task OnInitializedAsync()
    {
        // Db reference to campaign table, reference made in CampaignDetails model
        // Runs at start (async/await)
        campaignList = await appDbContext.Campaigns.ToListAsync();
    }
}