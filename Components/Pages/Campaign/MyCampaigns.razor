@page "/mycampaigns"
@using Microsoft.AspNetCore.Authorization
@using DnDNoteKeeper.Models
@using DnDNoteKeeper.Services
@attribute [Authorize]
@inject ICampaignService CampaignService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>My Campaigns - DnD Note Keeper</PageTitle>

<div class="container-fluid px-4 py-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="h3 mb-1">My Campaigns</h2>
            <p class="text-muted mb-0">Manage and edit your active adventures</p>
        </div>
        <a href="/campaigns/create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>New Campaign
        </a>
    </div>

    @if (campaigns == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading adventures...</p>
        </div>
    }
    else if (!campaigns.Any())
    {
        <div class="text-center py-5 border rounded bg-light">
            <i class="bi bi-map fs-1 text-muted"></i>
            <h4 class="mt-3">No campaigns found</h4>
            <a href="/campaigns/create" class="btn btn-primary mt-2">Create First Campaign</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="width: 100%;">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 80px;">Image</th>
                            <th>Campaign</th>
                            <th>Time</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var campaign in campaigns)
                        {
                            <tr role="button" @onclick="@(() => Navigation.NavigateTo($"/campaigns/{campaign.Id}"))" style="cursor: pointer;">
                                <td>
                                    <div class="rounded overflow-hidden" style="width: 50px; height: 50px;">
                                        @if (!string.IsNullOrEmpty(campaign.CampaignImage))
                                        {
                                            <img src="@campaign.CampaignImage" style="width: 100%; height: 100%; object-fit: cover;" alt="Campaign image" />
                                        }
                                        else
                                        {
                                            <img src="/images/campaignplaceholder.jpg" style="width: 100%; height: 100%; object-fit: cover;" alt="Placeholder campaign image" />
                                        }
                                    </div>
                                </td>
                                <td class="fw-bold text-primary">@campaign.CampaignName</td>
                                <td>@CampaignTime.getCampaignTime(campaign)</td>
                                <td class="text-end">
                                    <div class="btn-group" @onclick:stopPropagation="true">
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(campaign.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}